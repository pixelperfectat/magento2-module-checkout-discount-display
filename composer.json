{
    "name": "pixelperfectat/magento2-module-checkout-discount-display",
    "description": "Per-item discount messages and strikethrough pricing in the cart",
    "type": "magento2-module",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "magento/framework": "^103.0",
        "magento/module-checkout": "^100.0",
        "magento/module-quote": "^101.0",
        "magento/module-sales-rule": "^101.0",
        "pixelperfectat/magento2-module-discount-exclusion": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "pixelperfectat/coding-standard": "^0.1.0"
    },
    "suggest": {
        "hyva-themes/magento2-default-theme": "Required for cart page strikethrough pricing template"
    },
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "PixelPerfect\\CheckoutDiscountDisplay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PixelPerfect\\CheckoutDiscountDisplay\\Test\\": "Test/",
            "Amasty\\Affiliate\\": "Test/Stub/Amasty/Affiliate/"
        },
        "classmap": [
            "Test/Stub/Magento/"
        ]
    },
    "scripts": {
        "lint": "parallel-lint --exclude vendor --exclude generated .",
        "cs": "phpcs",
        "cs:fix": "phpcbf",
        "stan": "phpstan analyse",
        "test": "phpunit",
        "ci:validate": "@composer validate --no-check-publish",
        "check": [
            "@ci:validate",
            "@lint",
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "laminas/laminas-dependency-plugin": true,
            "magento/*": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.magento.com/"
        }
    ]
}
